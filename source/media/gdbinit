define sid
    si
    show_psw
    printf "R00 00000000 %08x  %08x %08x\n", $r1, $rp, $r3
    printf "R04 %08x %08x  %08x %08x\n", $r4, $r5, $r6, $r7
    printf "R08 %08x %08x  %08x %08x\n", $r8, $r9, $r10, $r11,
    printf "R12 %08x %08x  %08x %08x\n", $r12, $r13, $r14, $r15
    printf "R16 %08x %08x  %08x %08x\n", $r16, $r17, $r18, $r19
    printf "R20 %08x %08x  %08x %08x\n", $r20, $r21, $r22, $r23
    printf "R24 %08x %08x  %08x %08x\n", $r24, $r25, $r26, $dp
    printf "R28 %08x %08x  %08x %08x\n", $ret0, $ret1, $sp, $r31
    x/x $pc
    x/i $pc
end

define showregs64
    show_psw
    printf "R00 0000000000000000 %016lx  %016lx %016lx\n", $r1, $rp, $r3
    printf "R04 %016lx %016lx  %016lx %016lx\n", $r4, $r5, $r6, $r7
    printf "R08 %016lx %016lx  %016lx %016lx\n", $r8, $r9, $r10, $r11,
    printf "R12 %016lx %016lx  %016lx %016lx\n", $r12, $r13, $r14, $r15
    printf "R16 %016lx %016lx  %016lx %016lx\n", $r16, $r17, $r18, $r19
    printf "R20 %016lx %016lx  %016lx %016lx\n", $r20, $r21, $r22, $r23
    printf "R24 %016lx %016lx  %016lx %016lx\n", $r24, $r25, $r26, $dp
    printf "R28 %016lx %016lx  %016lx %016lx\n", $ret0, $ret1, $sp, $r31
    printf "SR0 %016lx %016lx  %016lx %016lx\n", $sr0, $sr1, $sr2, $sr3
    printf "SR4 %016lx %016lx  %016lx %016lx\n", $sr4, $sr5, $sr6, $sr7
    x/i $pc
end

define sid64
    si
    showregs64
end

define gvas
    set $addr = (unsigned long)$arg1 & 0x3fffffffffc
    x/$arg2 $addr | ((unsigned long)$arg0 << 32)
end

define gva
    set $sel = ((unsigned long)$arg0 >> 62)

    if $sel == 0
      gvas $sr4 $arg0 $arg1
    end
    if $sel == 1
      gvas $sr5 $arg0 $arg1
    end
    if $sel == 2
      gvas $sr6 $arg0 $arg1
    end
    if $sel == 3
      gvas $sr7 $arg0 $arg1
    end
end
