set auto-load safe-path /
set history save
set history filename ~/.gdbhistory
set print pretty
set print symbol-filename on
set print array
set input-radix 10
set output-radix 16
set confirm off
set verbose off
set height 0
set width 0
set debuginfod enabled on
set auto-load python-scripts off
#set disassembly-flavor intel
#set prompt \033[32mgdb> \033[0m
set style address foreground white
set style address intensity normal

define show_psw_bit
    if ($flags & $arg0)
        echo $arg1
    else
        echo -
    end
end

define show_psw
    printf "PSW                   CBCBCBCBYZ--WESTHLNXBCVMCBCBCBCB-GFRQPDI\n"
    printf "PSW %016lx: ", $flags
    show_psw_bit 0x8000000000 C
    show_psw_bit 0x4000000000 B
    show_psw_bit 0x2000000000 C
    show_psw_bit 0x1000000000 B
    show_psw_bit 0x0800000000 C
    show_psw_bit 0x0400000000 B
    show_psw_bit 0x0200000000 C
    show_psw_bit 0x0100000000 B
    show_psw_bit 0x0080000000 Y
    show_psw_bit 0x0040000000 Z
    show_psw_bit 0x0020000000 ?
    show_psw_bit 0x0010000000 ?
    show_psw_bit 0x0008000000 W
    show_psw_bit 0x0004000000 E
    show_psw_bit 0x0002000000 S
    show_psw_bit 0x0001000000 T
    show_psw_bit 0x0000800000 H
    show_psw_bit 0x0000400000 L
    show_psw_bit 0x0000200000 N
    show_psw_bit 0x0000100000 X
    show_psw_bit 0x0000080000 B
    show_psw_bit 0x0000040000 C
    show_psw_bit 0x0000020000 V
    show_psw_bit 0x0000010000 M
    show_psw_bit 0x0000008000 C
    show_psw_bit 0x0000004000 B
    show_psw_bit 0x0000002000 C
    show_psw_bit 0x0000001000 B
    show_psw_bit 0x0000000800 C
    show_psw_bit 0x0000000400 B
    show_psw_bit 0x0000000200 C
